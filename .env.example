# LOCAL EXECUTION ONLY.
# Copy this file to the repository-root .env. azd does not read it.
FOUNDRY_PROJECT_ENDPOINT=https://<foundry-resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4-mini

# Optional demo overrides. Defaults are safe mode and no message-content capture.
# HELPDESKBOT_MODE=vulnerable
# Only enable for an approved, isolated synthetic evaluation that requires it.
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
